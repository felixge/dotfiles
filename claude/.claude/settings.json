{
  "permissions": {
    "allow": [
      "Skill(jj)",
      "Skill(conventional-commits)",
      "Bash(jj *)",
      "Bash(bzl run //:gazelle *)",
      "Bash(bzl build *)",
      "Bash(bzl test *)",
      "Bash(bzl query *)",
      "Bash(go test *)",
      "Bash(tee *)",
      "Bash(go build *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(awk *)",
      "Bash(column *)",
      "Bash(which *)",
      "Bash(command *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(id *)",
      "Bash(whoami)",
      "Bash(make *)",
      "Bash(sed *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(go doc *)",
      "Bash(go tool *)",
      "Bash(go version *)",
      "Bash(go list *)",
      "Bash(go env *)",
      "Bash(go run *)",
      "Bash(cd *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(open *)",
      "Bash(mkdir *)",
      "Bash(fd *)",
      "Bash(ps *)",
      "Bash(tmux *)",
      "Bash(mise *)",
      "Bash(protoc *)",
      "Bash(benchstat *)",
      "Bash(dig *)",
      "Bash(snowsql *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh search *)",
      "Bash(gh api *)",
      "Bash(gh release view *)",
      "Read(*)",
      "mcp__datadog__*",
      "mcp__plugin_atlassian_atlassian__get*",
      "mcp__plugin_atlassian_atlassian__search",
      "mcp__plugin_atlassian_atlassian__search*",
      "mcp__plugin_atlassian_atlassian__lookup*",
      "mcp__plugin_atlassian_atlassian__fetch",
      "mcp__plugin_atlassian_atlassian__atlassianUserInfo"
    ],
    "deny": [
      "Bash(jj git push *)",
      "Bash(git add *)",
      "Bash(git am *)",
      "Bash(git apply *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      "Bash(git clean *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git init *)",
      "Bash(git merge *)",
      "Bash(git mv *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git revert *)",
      "Bash(git rm *)",
      "Bash(git stash *)",
      "Bash(git switch *)",
      "Read(.envrc)",
      "Read(~/.aws/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"curl -d \" + (.message | @sh) + \" -H \" + (\"Title: Claude Code (\" + (.cwd | split(\"/\") | last) + \")\" | @sh) + \" http://localhost:7878\"' | sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "gopls-lsp@claude-plugins-official": true,
    "dd@datadog-claude-plugins": true,
    "atlassian-remote-mcp@datadog-claude-plugins": true,
    "go-code-reviewer@datadog-claude-plugins": true,
    "clangd-lsp@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "agent-browser@agent-browser": true,
    "atlassian@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "datadog-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "DataDog/claude-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker:*",
      "jj:*"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
