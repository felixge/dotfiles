{
  "permissions": {
    "allow": [
      "Skill(jj)",
      "Skill(conventional-commits)",
      "Bash(jj *)",
      "Bash(bzl run //:gazelle *)",
      "Bash(bzl build *)",
      "Bash(bzl test *)",
      "Bash(bzl query *)",
      "Bash(go test *)",
      "Bash(tee *)",
      "Bash(go build *)",
      "Bash(find *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Read(*)",
      "mcp__datadog__*"
    ],
    "deny": [
      "Bash(jj git *)",

      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git revert *)",
      "Bash(git rm *)",
      "Bash(git mv *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git clean *)",
      "Bash(git init *)",
      "Bash(git clone *)",
      "Bash(git apply *)",
      "Bash(git am *)",

      "Read(.envrc)",
      "Read(~/.aws/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"curl -d \" + (.message | @sh) + \" -H \" + (\"Title: Claude Code (\" + (.cwd | split(\"/\") | last) + \")\" | @sh) + \" http://localhost:7878\"' | sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "gopls-lsp@claude-plugins-official": true,
    "dd@datadog-claude-plugins": true,
    "atlassian-remote-mcp@datadog-claude-plugins": true,
    "go-code-reviewer@datadog-claude-plugins": true,
    "clangd-lsp@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "agent-browser@agent-browser": true,
    "atlassian@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "datadog-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "DataDog/claude-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker:*",
      "jj:*"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
